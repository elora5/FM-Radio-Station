<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="540.0" prefWidth="820.0" style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #fff5f8);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Elora.listener.CreateandEditprofileController">

    <children>

        <Label layoutX="255.0" layoutY="18.0" style="-fx-text-fill: #b03060; -fx-font-weight: bold;" text="👤 Create  Edit Profile">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <AnchorPane layoutX="20.0" layoutY="60.0" prefHeight="430.0" prefWidth="780.0" style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-width: 2; -fx-border-radius: 16; -fx-background-radius: 16;">
            <children>

                <Label layoutX="25.0" layoutY="18.0" style="-fx-text-fill: #c2185b; -fx-font-weight: bold;" text="💖 Listener Profile Information">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>

                <Separator layoutX="20.0" layoutY="48.0" prefWidth="735.0" />

                <Label layoutX="35.0" layoutY="72.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="🆔 Profile ID:" />
                <TextField fx:id="profileIdTextField" layoutX="160.0" layoutY="67.0" prefHeight="30.0" prefWidth="200.0" promptText="Enter profile ID" style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="405.0" layoutY="72.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="🙍 Full Name:" />
                <TextField fx:id="fullNameTextField" layoutX="525.0" layoutY="67.0" prefHeight="30.0" prefWidth="210.0" promptText="Enter full name" style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="35.0" layoutY="122.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="📧 Email:" />
                <TextField fx:id="emailTextField" layoutX="160.0" layoutY="117.0" prefHeight="30.0" prefWidth="200.0" promptText="Enter email" style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="405.0" layoutY="122.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="📱 Phone:" />
                <TextField fx:id="phoneTextField" layoutX="525.0" layoutY="117.0" prefHeight="30.0" prefWidth="210.0" promptText="Enter phone number" style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="35.0" layoutY="172.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="🎂 Date of Birth:" />
                <DatePicker fx:id="dobDatePicker" layoutX="160.0" layoutY="167.0" prefHeight="30.0" prefWidth="200.0" style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="405.0" layoutY="172.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="⚧ Gender:" />
                <ComboBox fx:id="genderComboBox" layoutX="525.0" layoutY="167.0" prefHeight="30.0" prefWidth="210.0" promptText="Select gender" style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="35.0" layoutY="222.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="🏠 Address:" />
                <TextArea fx:id="addressTextArea" layoutX="160.0" layoutY="217.0" prefHeight="65.0" prefWidth="575.0" promptText="Enter address" style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="35.0" layoutY="305.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="🎵 Favorite Genre:" />
                <ComboBox fx:id="favoriteGenreComboBox" layoutX="160.0" layoutY="300.0" prefHeight="30.0" prefWidth="200.0" promptText="Select genre" style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <Label layoutX="405.0" layoutY="305.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="📻 Listener Type:" />
                <RadioButton fx:id="regularRadioButton" layoutX="525.0" layoutY="305.0" style="-fx-text-fill: #7a294f;" text="Regular" />
                <RadioButton fx:id="premiumRadioButton" layoutX="620.0" layoutY="305.0" style="-fx-text-fill: #7a294f;" text="Premium" />

                <Label layoutX="35.0" layoutY="352.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="✨ Interests:" />
                <CheckBox fx:id="musicCheckBox" layoutX="160.0" layoutY="352.0" style="-fx-text-fill: #7a294f;" text="Music" />
                <CheckBox fx:id="newsCheckBox" layoutX="240.0" layoutY="352.0" style="-fx-text-fill: #7a294f;" text="News" />
                <CheckBox fx:id="sportsCheckBox" layoutX="315.0" layoutY="352.0" style="-fx-text-fill: #7a294f;" text="Sports" />
                <CheckBox fx:id="talkShowCheckBox" layoutX="395.0" layoutY="352.0" style="-fx-text-fill: #7a294f;" text="Talk Show" />

                <Button layoutX="135.0" layoutY="390.0" onAction="#loadButtonOnClick" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #f8a5c2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="📂 Load" />

                <Button layoutX="255.0" layoutY="390.0" onAction="#saveButtonOnClick" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #ec5f9e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="💾 Save" />

                <Button layoutX="375.0" layoutY="390.0" onAction="#updateButtonOnClick" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #d63384; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="✏ Update" />

                <Button layoutX="505.0" layoutY="390.0" onAction="#clearButtonOnClick" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #f78fb3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🧹 Clear" />

                <Button layoutX="625.0" layoutY="390.0" onAction="#backButtonOnClick" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #c44569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="⬅ Back" />

            </children>
        </AnchorPane>

    </children>
</AnchorPane>
