<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="820.0"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #fff5f8);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oop.fmradiostation.Elora.finance_officer.SetAdSlotPrisingSceneController">

    <children>

        <Label layoutX="255.0" layoutY="15.0" text="Set Ad Slot Pricing"
               style="-fx-text-fill: #b03060; -fx-font-weight: bold;">
            <font>
                <Font size="24.0"/>
            </font>
        </Label>

        <!-- Input Section -->
        <AnchorPane layoutX="20.0" layoutY="55.0" prefHeight="170.0" prefWidth="780.0"
                    style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-width: 2; -fx-border-radius: 14; -fx-background-radius: 14;">
            <children>

                <Label layoutX="20.0" layoutY="15.0" text="Slot Pricing Information"
                       style="-fx-text-fill: #c2185b; -fx-font-weight: bold;">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <Separator layoutX="18.0" layoutY="45.0" prefWidth="740.0"/>

                <Label layoutX="25.0" layoutY="65.0" text="Slot ID:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="slotIdTextField" layoutX="110.0" layoutY="60.0" prefHeight="30.0" prefWidth="150.0"
                           promptText="Enter slot ID"
                           style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Label layoutX="290.0" layoutY="65.0" text="Slot Type:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <ComboBox fx:id="slotTypeComboBox" layoutX="370.0" layoutY="60.0" prefHeight="30.0" prefWidth="160.0"
                          promptText="Select type"
                          style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Label layoutX="555.0" layoutY="65.0" text="Duration:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="durationTextField" layoutX="625.0" layoutY="60.0" prefHeight="30.0" prefWidth="120.0"
                           promptText="Seconds"
                           style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Label layoutX="25.0" layoutY="110.0" text="Time Slot:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <ComboBox fx:id="timeSlotComboBox" layoutX="110.0" layoutY="105.0" prefHeight="30.0" prefWidth="150.0"
                          promptText="Select slot"
                          style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Label layoutX="290.0" layoutY="110.0" text="Base Price:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="basePriceTextField" layoutX="370.0" layoutY="105.0" prefHeight="30.0" prefWidth="160.0"
                           promptText="Enter price"
                           style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Label layoutX="555.0" layoutY="110.0" text="Effective Date:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <DatePicker fx:id="effectiveDatePicker" layoutX="655.0" layoutY="105.0" prefHeight="30.0" prefWidth="90.0"
                            style="-fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

            </children>
        </AnchorPane>

        <!-- Table Section -->
        <AnchorPane layoutX="20.0" layoutY="240.0" prefHeight="190.0" prefWidth="780.0"
                    style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-width: 2; -fx-border-radius: 14; -fx-background-radius: 14;">
            <children>

                <Label layoutX="20.0" layoutY="15.0" text="Ad Slot Pricing Records"
                       style="-fx-text-fill: #c2185b; -fx-font-weight: bold;">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <TableView fx:id="slotPricingTableView" layoutX="18.0" layoutY="45.0" prefHeight="130.0" prefWidth="744.0">
                    <columns>
                        <TableColumn fx:id="slotIdColumn" prefWidth="90.0" text="Slot ID"/>
                        <TableColumn fx:id="slotTypeColumn" prefWidth="130.0" text="Slot Type"/>
                        <TableColumn fx:id="timeSlotColumn" prefWidth="130.0" text="Time Slot"/>
                        <TableColumn fx:id="durationColumn" prefWidth="90.0" text="Duration"/>
                        <TableColumn fx:id="priceColumn" prefWidth="120.0" text="Price"/>
                        <TableColumn fx:id="effectiveDateColumn" prefWidth="120.0" text="Effective Date"/>
                        <TableColumn fx:id="statusColumn" prefWidth="60.0" text="Status"/>
                    </columns>
                </TableView>

            </children>
        </AnchorPane>

        <!-- Bottom Action Section -->
        <AnchorPane layoutX="20.0" layoutY="445.0" prefHeight="60.0" prefWidth="780.0"
                    style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-width: 2; -fx-border-radius: 14; -fx-background-radius: 14;">
            <children>

                <TextArea fx:id="noteTextArea" layoutX="15.0" layoutY="10.0" prefHeight="40.0" prefWidth="250.0"
                          promptText="Write pricing note..."
                          style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                <Button fx:id="loadButton" layoutX="295.0" layoutY="15.0" prefHeight="30.0" prefWidth="80.0" text="Load"
                        style="-fx-background-color: #f8a5c2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="saveButton" layoutX="390.0" layoutY="15.0" prefHeight="30.0" prefWidth="80.0" text="Save"
                        style="-fx-background-color: #ec5f9e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="updateButton" layoutX="485.0" layoutY="15.0" prefHeight="30.0" prefWidth="80.0" text="Update"
                        style="-fx-background-color: #d63384; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="clearButton" layoutX="580.0" layoutY="15.0" prefHeight="30.0" prefWidth="80.0" text="Clear"
                        style="-fx-background-color: #f78fb3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="backButton" layoutX="675.0" layoutY="15.0" prefHeight="30.0" prefWidth="80.0" text="Back"
                        style="-fx-background-color: #c44569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>