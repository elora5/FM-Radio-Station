<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #fff0f5);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Elora.finance_officer.AddOrModifiedAdvertiseSceneController">

    <children>
        <Label layoutX="295.0" layoutY="20.0" style="-fx-text-fill: #b03060; -fx-font-weight: bold;" text="Add / Modify Advertisement">
            <font>
                <Font size="28.0" />
            </font>
        </Label>

        <AnchorPane layoutX="35.0" layoutY="70.0" prefHeight="540.0" prefWidth="880.0" style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-radius: 18; -fx-border-color: #f4a6c1; -fx-border-width: 2;">
            <children>

                <Label layoutX="30.0" layoutY="25.0" style="-fx-text-fill: #c2185b; -fx-font-weight: bold;" text="Advertisement Information">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Label>

                <Separator layoutX="28.0" layoutY="60.0" prefWidth="820.0" />

                <Label layoutX="40.0" layoutY="85.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Advertisement ID:" />
                <TextField fx:id="advertiseIdField" layoutX="190.0" layoutY="80.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter advertisement ID" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Label layoutX="450.0" layoutY="85.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Company Name:" />
                <TextField fx:id="companyNameField" layoutX="580.0" layoutY="80.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter company name" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Label layoutX="40.0" layoutY="135.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Advertisement Title:" />
                <TextField fx:id="advertiseTitleField" layoutX="190.0" layoutY="130.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter ad title" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Label layoutX="450.0" layoutY="135.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Duration (sec):" />
                <TextField fx:id="durationField" layoutX="580.0" layoutY="130.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter duration" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Label layoutX="40.0" layoutY="185.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Budget:" />
                <TextField fx:id="budgetField" layoutX="190.0" layoutY="180.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter budget" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Label layoutX="450.0" layoutY="185.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Ad Type:" />
                <ComboBox fx:id="adTypeComboBox" layoutX="580.0" layoutY="180.0" prefHeight="30.0" prefWidth="220.0" style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;" />

                <Label layoutX="40.0" layoutY="235.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Start Date:" />
                <DatePicker fx:id="startDatePicker" layoutX="190.0" layoutY="230.0" prefHeight="30.0" prefWidth="220.0" style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;" />

                <Label layoutX="450.0" layoutY="235.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="End Date:" />
                <DatePicker fx:id="endDatePicker" layoutX="580.0" layoutY="230.0" prefHeight="30.0" prefWidth="220.0" style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;" />

                <Label layoutX="40.0" layoutY="285.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Preferred Time Slot:" />
                <ComboBox fx:id="timeSlotComboBox" layoutX="190.0" layoutY="280.0" prefHeight="30.0" prefWidth="220.0" style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;" />

                <Label layoutX="450.0" layoutY="285.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Status:" />
                <ComboBox fx:id="statusComboBox" layoutX="580.0" layoutY="280.0" prefHeight="30.0" prefWidth="220.0" style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;" />

                <Label layoutX="40.0" layoutY="335.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Broadcast Days:" />

                <CheckBox fx:id="mondayCheckBox" layoutX="190.0" layoutY="335.0" style="-fx-text-fill: #7a294f;" text="Monday" />
                <CheckBox fx:id="tuesdayCheckBox" layoutX="280.0" layoutY="335.0" style="-fx-text-fill: #7a294f;" text="Tuesday" />
                <CheckBox fx:id="wednesdayCheckBox" layoutX="370.0" layoutY="335.0" style="-fx-text-fill: #7a294f;" text="Wednesday" />
                <CheckBox fx:id="thursdayCheckBox" layoutX="490.0" layoutY="335.0" style="-fx-text-fill: #7a294f;" text="Thursday" />
                <CheckBox fx:id="fridayCheckBox" layoutX="600.0" layoutY="335.0" style="-fx-text-fill: #7a294f;" text="Friday" />
                <CheckBox fx:id="saturdayCheckBox" layoutX="190.0" layoutY="365.0" style="-fx-text-fill: #7a294f;" text="Saturday" />
                <CheckBox fx:id="sundayCheckBox" layoutX="280.0" layoutY="365.0" style="-fx-text-fill: #7a294f;" text="Sunday" />

                <Label layoutX="450.0" layoutY="365.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Mode:" />

                <RadioButton fx:id="newAdRadioButton" layoutX="580.0" layoutY="365.0" style="-fx-text-fill: #7a294f;" text="New" />
                <RadioButton fx:id="modifyAdRadioButton" layoutX="650.0" layoutY="365.0" style="-fx-text-fill: #7a294f;" text="Modify" />

                <Label layoutX="40.0" layoutY="415.0" style="-fx-text-fill: #7a294f; -fx-font-weight: bold;" text="Additional Notes:" />
                <TextArea fx:id="notesTextArea" layoutX="190.0" layoutY="410.0" prefHeight="80.0" prefWidth="610.0" promptText="Write additional notes here..." style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;" />

                <Button layoutX="120.0" layoutY="505.0" onAction="#loadButtonOnClick" style="-fx-background-color: #f8a5c2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Load" />
                <Button layoutX="260.0" layoutY="505.0" onAction="#saveButtonOnClick" style="-fx-background-color: #ec5f9e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Save" />
                <Button layoutX="400.0" layoutY="505.0" onAction="#updateButtonOnClick" style="-fx-background-color: #d63384; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Update" />
                <Button layoutX="540.0" layoutY="505.0" onAction="#clearButtonOnClick" style="-fx-background-color: #f78fb3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Clear" />
                <Button layoutX="680.0" layoutY="505.0" onAction="#backButtonOnClick" style="-fx-background-color: #c44569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Back" />

            </children>
        </AnchorPane>
    </children>
</AnchorPane>
