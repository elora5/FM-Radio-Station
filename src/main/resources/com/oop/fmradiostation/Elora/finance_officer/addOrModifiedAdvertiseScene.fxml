<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="950.0"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #fff0f5);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oop.fmradiostation.Elora.finance_officer.AddOrModifiedAdvertiseSceneController">

    <children>
        <Label layoutX="295.0" layoutY="20.0" text="Add / Modify Advertisement"
               style="-fx-text-fill: #b03060; -fx-font-weight: bold;">
            <font>
                <Font size="28.0"/>
            </font>
        </Label>

        <AnchorPane layoutX="35.0" layoutY="70.0" prefHeight="540.0" prefWidth="880.0"
                    style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-radius: 18; -fx-border-color: #f4a6c1; -fx-border-width: 2;">
            <children>

                <Label layoutX="30.0" layoutY="25.0" text="Advertisement Information"
                       style="-fx-text-fill: #c2185b; -fx-font-weight: bold;">
                    <font>
                        <Font size="20.0"/>
                    </font>
                </Label>

                <Separator layoutX="28.0" layoutY="60.0" prefWidth="820.0"/>

                <Label layoutX="40.0" layoutY="85.0" text="Advertisement ID:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="advertiseIdField" layoutX="190.0" layoutY="80.0" prefHeight="30.0" prefWidth="220.0"
                           promptText="Enter advertisement ID"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Label layoutX="450.0" layoutY="85.0" text="Company Name:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="companyNameField" layoutX="580.0" layoutY="80.0" prefHeight="30.0" prefWidth="220.0"
                           promptText="Enter company name"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Label layoutX="40.0" layoutY="135.0" text="Advertisement Title:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="advertiseTitleField" layoutX="190.0" layoutY="130.0" prefHeight="30.0" prefWidth="220.0"
                           promptText="Enter ad title"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Label layoutX="450.0" layoutY="135.0" text="Duration (sec):"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="durationField" layoutX="580.0" layoutY="130.0" prefHeight="30.0" prefWidth="220.0"
                           promptText="Enter duration"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Label layoutX="40.0" layoutY="185.0" text="Budget:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextField fx:id="budgetField" layoutX="190.0" layoutY="180.0" prefHeight="30.0" prefWidth="220.0"
                           promptText="Enter budget"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Label layoutX="450.0" layoutY="185.0" text="Ad Type:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <ComboBox fx:id="adTypeComboBox" layoutX="580.0" layoutY="180.0" prefHeight="30.0" prefWidth="220.0"
                          style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;"/>

                <Label layoutX="40.0" layoutY="235.0" text="Start Date:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <DatePicker fx:id="startDatePicker" layoutX="190.0" layoutY="230.0" prefHeight="30.0" prefWidth="220.0"
                            style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;"/>

                <Label layoutX="450.0" layoutY="235.0" text="End Date:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <DatePicker fx:id="endDatePicker" layoutX="580.0" layoutY="230.0" prefHeight="30.0" prefWidth="220.0"
                            style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;"/>

                <Label layoutX="40.0" layoutY="285.0" text="Preferred Time Slot:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <ComboBox fx:id="timeSlotComboBox" layoutX="190.0" layoutY="280.0" prefHeight="30.0" prefWidth="220.0"
                          style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;"/>

                <Label layoutX="450.0" layoutY="285.0" text="Status:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <ComboBox fx:id="statusComboBox" layoutX="580.0" layoutY="280.0" prefHeight="30.0" prefWidth="220.0"
                          style="-fx-background-radius: 10; -fx-border-color: #f4a6c1; -fx-border-radius: 10;"/>

                <Label layoutX="40.0" layoutY="335.0" text="Broadcast Days:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>

                <CheckBox fx:id="mondayCheckBox" layoutX="190.0" layoutY="335.0" text="Monday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="tuesdayCheckBox" layoutX="280.0" layoutY="335.0" text="Tuesday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="wednesdayCheckBox" layoutX="370.0" layoutY="335.0" text="Wednesday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="thursdayCheckBox" layoutX="490.0" layoutY="335.0" text="Thursday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="fridayCheckBox" layoutX="600.0" layoutY="335.0" text="Friday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="saturdayCheckBox" layoutX="190.0" layoutY="365.0" text="Saturday"
                          style="-fx-text-fill: #7a294f;"/>
                <CheckBox fx:id="sundayCheckBox" layoutX="280.0" layoutY="365.0" text="Sunday"
                          style="-fx-text-fill: #7a294f;"/>

                <Label layoutX="450.0" layoutY="365.0" text="Mode:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>

                <RadioButton fx:id="newAdRadioButton" layoutX="580.0" layoutY="365.0" text="New"
                             style="-fx-text-fill: #7a294f;"/>
                <RadioButton fx:id="modifyAdRadioButton" layoutX="650.0" layoutY="365.0" text="Modify"
                             style="-fx-text-fill: #7a294f;"/>

                <Label layoutX="40.0" layoutY="415.0" text="Additional Notes:"
                       style="-fx-text-fill: #7a294f; -fx-font-weight: bold;"/>
                <TextArea fx:id="notesTextArea" layoutX="190.0" layoutY="410.0" prefHeight="80.0" prefWidth="610.0"
                          promptText="Write additional notes here..."
                          style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #f4a6c1; -fx-background-color: #fff7fa;"/>

                <Button fx:id="loadButton" layoutX="120.0" layoutY="505.0" text="Load"
                        style="-fx-background-color: #f8a5c2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>
                <Button fx:id="saveButton" layoutX="260.0" layoutY="505.0" text="Save"
                        style="-fx-background-color: #ec5f9e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>
                <Button fx:id="updateButton" layoutX="400.0" layoutY="505.0" text="Update"
                        style="-fx-background-color: #d63384; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>
                <Button fx:id="clearButton" layoutX="540.0" layoutY="505.0" text="Clear"
                        style="-fx-background-color: #f78fb3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>
                <Button fx:id="backButton" layoutX="680.0" layoutY="505.0" text="Back"
                        style="-fx-background-color: #c44569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

            </children>
        </AnchorPane>
    </children>
</AnchorPane>