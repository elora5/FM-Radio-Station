<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #fff5f8);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oop.fmradiostation.Elora.finance_officer.MonitorAdvertisementSceneController">

    <children>


        <Label layoutX="250.0" layoutY="15.0" text="Monitor Advertisement"
               style="-fx-text-fill: #b03060; -fx-font-weight: bold;">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>


        <AnchorPane layoutX="20.0" layoutY="50.0" prefHeight="100.0" prefWidth="760.0"
                    style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-radius: 12; -fx-background-radius: 12;">
            <children>

                <TextField fx:id="advertisementIdTextField" layoutX="15.0" layoutY="35.0"
                           prefWidth="120.0" promptText="Ad ID"
                           style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1;"/>

                <TextField fx:id="companyTextField" layoutX="145.0" layoutY="35.0"
                           prefWidth="140.0" promptText="Company"
                           style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1;"/>

                <ComboBox fx:id="statusComboBox" layoutX="295.0" layoutY="35.0"
                          prefWidth="120.0" promptText="Status"
                          style="-fx-border-color: #f4a6c1;"/>

                <DatePicker fx:id="monitorDatePicker" layoutX="425.0" layoutY="35.0"
                            prefWidth="130.0"
                            style="-fx-border-color: #f4a6c1;"/>

                <Button fx:id="searchButton" layoutX="570.0" layoutY="35.0"
                        prefWidth="70.0" text="Search"
                        style="-fx-background-color: #f78fb3; -fx-text-fill: white;"/>

                <Button fx:id="clearButton" layoutX="650.0" layoutY="35.0"
                        prefWidth="70.0" text="Clear"
                        style="-fx-background-color: #ec5f9e; -fx-text-fill: white;"/>

            </children>
        </AnchorPane>


        <TableView fx:id="advertisementTableView" layoutX="20.0" layoutY="170.0"
                   prefHeight="200.0" prefWidth="760.0">

            <columns>
                <TableColumn fx:id="adIdColumn" prefWidth="80.0" text="ID"/>
                <TableColumn fx:id="companyColumn" prefWidth="120.0" text="Company"/>
                <TableColumn fx:id="titleColumn" prefWidth="150.0" text="Title"/>
                <TableColumn fx:id="typeColumn" prefWidth="100.0" text="Type"/>
                <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status"/>
                <TableColumn fx:id="startDateColumn" prefWidth="100.0" text="Start"/>
                <TableColumn fx:id="endDateColumn" prefWidth="100.0" text="End"/>
            </columns>

        </TableView>


        <AnchorPane layoutX="20.0" layoutY="390.0" prefHeight="90.0" prefWidth="760.0"
                    style="-fx-background-color: white; -fx-border-color: #f4a6c1; -fx-border-radius: 12; -fx-background-radius: 12;">
            <children>

                <Label layoutX="15.0" layoutY="10.0" text="Summary"
                       style="-fx-text-fill: #c2185b; -fx-font-weight: bold;"/>

                <TextField fx:id="totalAdsTextField" layoutX="15.0" layoutY="35.0"
                           prefWidth="100.0" promptText="Total" editable="false"
                           style="-fx-background-color: #fff8fb;"/>

                <TextField fx:id="runningAdsTextField" layoutX="130.0" layoutY="35.0"
                           prefWidth="100.0" promptText="Running" editable="false"
                           style="-fx-background-color: #fff8fb;"/>

                <TextField fx:id="pendingAdsTextField" layoutX="245.0" layoutY="35.0"
                           prefWidth="100.0" promptText="Pending" editable="false"
                           style="-fx-background-color: #fff8fb;"/>

                <TextArea fx:id="remarksTextArea" layoutX="360.0" layoutY="20.0"
                          prefWidth="250.0" prefHeight="50.0"
                          promptText="Remarks..."
                          style="-fx-background-color: #fff8fb; -fx-border-color: #f4a6c1;"/>

                <Button fx:id="refreshButton" layoutX="630.0" layoutY="20.0"
                        prefWidth="100.0" text="Refresh"
                        style="-fx-background-color: #d63384; -fx-text-fill: white;"/>

                <Button fx:id="backButton" layoutX="630.0" layoutY="50.0"
                        prefWidth="100.0" text="Back"
                        style="-fx-background-color: #c44569; -fx-text-fill: white;"/>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>