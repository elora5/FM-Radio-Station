<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.ManageConflictsController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="300.0" prefWidth="200.0" spacing="15.0">
            <children>
                <Label text="Select a conflicted schedule from the table, then choose a backup studio." wrapText="true" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="Re-assign to Studio:" />
                        <ComboBox fx:id="backupStudioComboBox" prefWidth="200.0" promptText="Choose Backup Studio..." />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleResolveConflict" prefHeight="35.0" prefWidth="200.0" text="Resolve Conflict">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="conflictTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0" style="-fx-border-width: 2;">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="70.0" text="Sched ID" />
                <TableColumn fx:id="programCol" prefWidth="120.0" text="Program" />
                <TableColumn fx:id="timeCol" prefWidth="100.0" text="Time" />
                <TableColumn fx:id="conflictCol" prefWidth="100.0" text="Conflict Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
