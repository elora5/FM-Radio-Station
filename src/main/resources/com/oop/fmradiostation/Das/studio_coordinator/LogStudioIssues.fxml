<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.LogStudioIssuesController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="350.0" prefWidth="200.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Studio:" />
                        <ComboBox fx:id="studioComboBox" prefWidth="200.0" promptText="Choose Studio..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Issue Description:" />
                        <TextArea fx:id="descriptionArea" prefHeight="100.0" prefWidth="200.0" promptText="Describe the problem here..." wrapText="true" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleSubmitIssue" prefHeight="35.0" prefWidth="200.0" text="Submit Issue Report">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="issueTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="70.0" text="Issue ID" />
                <TableColumn fx:id="studioCol" prefWidth="90.0" text="Studio" />
                <TableColumn fx:id="descCol" prefWidth="160.0" text="Description" />
                <TableColumn fx:id="statusCol" prefWidth="75.0" text="Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
