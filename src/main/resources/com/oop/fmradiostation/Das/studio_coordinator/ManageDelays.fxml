<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.ManageDelaysController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="250.0" prefWidth="200.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Program:" />
                        <ComboBox fx:id="programComboBox" prefWidth="200.0" promptText="Choose a program..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Delay Duration (Minutes):" />
                        <TextField fx:id="durationTextField" promptText="e.g., 15" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Reason for Delay:" />
                        <TextField fx:id="reasonTextField" promptText="e.g., Technical issue, RJ late" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleApplyDelay" prefHeight="35.0" prefWidth="200.0" text="Apply Delay">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="scheduleTable" layoutX="260.0" layoutY="80.0" prefHeight="480.0" prefWidth="390.0">
            <columns>
                <TableColumn fx:id="programCol" prefWidth="140.0" text="Program Name" />
                <TableColumn fx:id="startCol" minWidth="0.0" prefWidth="85.0" text="Start Time" />
                <TableColumn fx:id="endCol" prefWidth="85.0" text="End Time" />
                <TableColumn fx:id="delayCol" prefWidth="75.0" text="Delay (m)" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
