<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.CloseStudioController">
    <children>

        <VBox alignment="CENTER" layoutX="140.0" layoutY="150.0" prefHeight="250.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 10;">
            <children>
                <Label text="Select an active studio to close it for the day." textFill="#7f8c8d" />
                <ComboBox fx:id="activeStudioComboBox" prefHeight="35.0" prefWidth="300.0" promptText="Select Active Studio..." />
                <Button mnemonicParsing="false" onAction="#handleCloseStudio" prefHeight="45.0" prefWidth="300.0" text="Confirm Studio Closure">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>
    </children>
</AnchorPane>
