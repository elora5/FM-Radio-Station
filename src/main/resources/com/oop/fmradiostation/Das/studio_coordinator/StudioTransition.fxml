<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.StudioTransitionController">
    <children>

        <VBox alignment="CENTER" layoutX="140.0" layoutY="120.0" prefHeight="350.0" prefWidth="400.0" spacing="25.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 10;">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Ending Program:" />
                        <ComboBox fx:id="currentProgramComboBox" prefWidth="350.0" promptText="Select Current Program..." />
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="↓ Transitioning To ↓" textFill="#7f8c8d">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Next Scheduled Program:" />
                        <ComboBox fx:id="nextProgramComboBox" prefWidth="350.0" promptText="Select Next Program..." />
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#handleExecuteTransition" prefHeight="40.0" prefWidth="350.0" text="Execute Transition">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
            </children>
        </VBox>
    </children>
</AnchorPane>
