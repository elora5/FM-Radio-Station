<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.AllocateStudioController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="300.0" prefWidth="200.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Studio:" />
                        <ComboBox fx:id="studioComboBox" prefWidth="200.0" promptText="Choose Studio..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Program:" />
                        <ComboBox fx:id="programComboBox" prefWidth="200.0" promptText="Choose Program..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Date:" />
                        <DatePicker fx:id="scheduleDatePicker" prefWidth="200.0" promptText="Pick a date" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleAllocate" prefHeight="35.0" prefWidth="200.0" text="Confirm Allocation">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="scheduleTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="60.0" text="Sched ID" />
                <TableColumn fx:id="studioCol" prefWidth="100.0" text="Studio" />
                <TableColumn fx:id="programCol" prefWidth="140.0" text="Program" />
                <TableColumn fx:id="dateCol" prefWidth="100.0" text="Date" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
