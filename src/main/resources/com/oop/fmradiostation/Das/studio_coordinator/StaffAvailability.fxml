<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.studio_coordinator.StaffAvailabilityController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="250.0" prefWidth="200.0" spacing="15.0">
            <children>
                <Label text="Filter staff schedule by role or availability status." textFill="#7f8c8d" wrapText="true" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="Filter by Role:" />
                        <ComboBox fx:id="roleComboBox" prefWidth="200.0" promptText="e.g., Radio Jockey" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleCheckAvailability" prefHeight="35.0" prefWidth="200.0" text="Fetch Schedule">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="staffTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="nameCol" prefWidth="120.0" text="Staff Name" />
                <TableColumn fx:id="roleCol" prefWidth="100.0" text="Role" />
                <TableColumn fx:id="shiftCol" prefWidth="100.0" text="Assigned Shift" />
                <TableColumn fx:id="statusCol" prefWidth="75.0" text="Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
