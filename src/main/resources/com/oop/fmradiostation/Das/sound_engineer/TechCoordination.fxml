<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.sound_engineer.TechCoordinationController">
    <children>
        <Label layoutX="30.0" layoutY="25.0" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="200.0" prefWidth="200.0" spacing="15.0">
            <children>
                <Label text="Select a pending request from the table to provide technical clearance." textFill="#7f8c8d" wrapText="true" />
                <Button mnemonicParsing="false" onAction="#handleConfirmReadiness" prefHeight="35.0" prefWidth="200.0" text="Confirm Studio is Ready">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="requestsTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="studioCol" prefWidth="100.0" text="Studio" />
                <TableColumn fx:id="programCol" prefWidth="130.0" text="Program" />
                <TableColumn fx:id="timeCol" prefWidth="80.0" text="Time" />
                <TableColumn fx:id="statusCol" prefWidth="85.0" text="Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
