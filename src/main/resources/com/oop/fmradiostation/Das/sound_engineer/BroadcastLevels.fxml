<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.sound_engineer.BroadcastLevelsController">
    <children>

        <VBox layoutX="140.0" layoutY="120.0" prefHeight="300.0" prefWidth="400.0" spacing="25.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 10;">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Audio Channel:" />
                        <ComboBox fx:id="channelComboBox" prefWidth="350.0" promptText="Choose Output Channel..." />
                    </children>
                </VBox>

                <VBox spacing="10.0">
                    <children>
                        <Label text="Volume Level (dB):" />
                        <Slider fx:id="volumeSlider" blockIncrement="5.0" majorTickUnit="20.0" minorTickCount="5" showTickLabels="true" showTickMarks="true" value="50.0" />
                        <Label fx:id="currentVolumeLabel" text="Current: 50.0 dB">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#handleSetLevels" prefHeight="40.0" prefWidth="350.0" text="Apply Broadcast Levels">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
            </children>
        </VBox>
    </children>
</AnchorPane>
