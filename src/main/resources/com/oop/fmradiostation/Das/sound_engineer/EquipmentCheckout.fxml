<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.sound_engineer.EquipmentCheckoutController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="300.0" prefWidth="200.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Equipment:" />
                        <ComboBox fx:id="equipmentComboBox" prefWidth="200.0" promptText="Choose gear..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Assign To (Name):" />
                        <TextField fx:id="assigneeField" promptText="e.g., Reporter John" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleCheckout" prefHeight="35.0" prefWidth="200.0" text="Checkout Gear">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="checkoutTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="70.0" text="Assign ID" />
                <TableColumn fx:id="gearCol" prefWidth="120.0" text="Equipment" />
                <TableColumn fx:id="personCol" prefWidth="120.0" text="Assigned To" />
                <TableColumn fx:id="statusCol" prefWidth="85.0" text="Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
