<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.fmradiostation.Das.sound_engineer.MaintenanceLogController">
    <children>

        <VBox layoutX="30.0" layoutY="80.0" prefHeight="350.0" prefWidth="200.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Equipment:" />
                        <ComboBox fx:id="deviceComboBox" prefWidth="200.0" promptText="Choose gear..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Action Taken / Notes:" />
                        <TextArea fx:id="notesArea" prefHeight="100.0" prefWidth="200.0" promptText="e.g., Replaced XLR cable, recalibrated..." wrapText="true" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleSaveLog" prefHeight="35.0" prefWidth="200.0" text="Save Maintenance Log">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="logTable" layoutX="250.0" layoutY="80.0" prefHeight="480.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="dateCol" prefWidth="90.0" text="Date" />
                <TableColumn fx:id="deviceCol" prefWidth="100.0" text="Equipment" />
                <TableColumn fx:id="notesCol" prefWidth="205.0" text="Maintenance Notes" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
